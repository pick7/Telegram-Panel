@inject Microsoft.AspNetCore.Hosting.IWebHostEnvironment WebHostEnvironment

<!DOCTYPE html>
<html lang="zh-CN">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <link href="https://fonts.googleapis.com/css?family=Roboto:300,400,500,700&display=swap" rel="stylesheet" />
    <link href="_content/MudBlazor/MudBlazor.min.css" rel="stylesheet" />
    <link href="@VersionedAsset("app.css")" rel="stylesheet" />
    <HeadOutlet @rendermode="CurrentRenderMode" />
</head>

<body>
    <Routes @rendermode="CurrentRenderMode" />
    <div id="components-reconnect-modal">
        <div class="components-reconnect-show">连接中断，正在重新连接...</div>
        <div class="components-reconnect-failed">
            连接已断开。
            <button type="button" onclick="location.reload()">刷新页面</button>
        </div>
        <div class="components-reconnect-rejected">
            服务器拒绝恢复当前页面，请刷新后重试。
            <button type="button" onclick="location.reload()">刷新页面</button>
        </div>
    </div>
    <div id="blazor-error-ui">
        <strong>页面运行出错。</strong>
        <span id="blazor-error-message">请刷新页面重试；如果这是旧模块页面，请复制浏览器控制台错误继续排查。</span>
        <button type="button" class="reload" onclick="location.reload()">刷新</button>
        <button type="button" class="dismiss" onclick="this.parentElement.style.display='none'">关闭</button>
    </div>
    <script src="_content/MudBlazor/MudBlazor.min.js"></script>
    <script src="_framework/blazor.web.js"></script>
    <script src="@VersionedAsset("app.js")"></script>
</body>

</html>

@code {
    private static readonly IComponentRenderMode PrerenderedServerRenderMode =
        new InteractiveServerRenderMode(prerender: true);

    private IComponentRenderMode CurrentRenderMode => PrerenderedServerRenderMode;

    private string VersionedAsset(string path)
    {
        var normalizedPath = (path ?? "").TrimStart('/', '\\');
        if (string.IsNullOrWhiteSpace(normalizedPath))
            return normalizedPath;

        try
        {
            if (string.IsNullOrWhiteSpace(WebHostEnvironment.WebRootPath))
                return normalizedPath;

            var filePath = System.IO.Path.Combine(
                WebHostEnvironment.WebRootPath,
                normalizedPath.Replace('/', System.IO.Path.DirectorySeparatorChar));

            if (System.IO.File.Exists(filePath))
            {
                var version = System.IO.File.GetLastWriteTimeUtc(filePath).Ticks.ToString(System.Globalization.CultureInfo.InvariantCulture);
                return $"{normalizedPath}?v={version}";
            }
        }
        catch
        {
            // 静态资源版本只用于破缓存，失败时保持原路径。
        }

        return normalizedPath;
    }
}
