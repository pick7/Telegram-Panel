{
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=telegram_panel.db"
  },
  "Telegram": {
    "ApiId": 0,
    "ApiHash": "",
    "SessionsPath": "sessions",
    "DefaultDelayMs": 2000,
    "MaxRetries": 3
  },
  "Proxy": {
    "Warp": {
      "Enabled": false,
      "DockerSocketPath": "/var/run/docker.sock",
      "Image": "caomingjun/warp:latest",
      "Network": "telegram-panel_default",
      "ContainerPrefix": "telegram-panel-warp",
      "Protocol": "http",
      "ContainerPort": 1080,
      "HostPortStart": 42080,
      "ProxyHostMode": "container",
      "ProxyHost": "127.0.0.1",
      "PullIfMissing": true
    }
  },
  "TelegramStatus": {
    "AutoRefreshTransientFailures": true,
    "AutoRefreshIntervalMinutes": 30,
    "AutoRefreshBatchSize": 3,
    "AutoRefreshMinAgeMinutes": 10,
    "AutoRefreshDelayMs": 5000
  },
  "AdminAuth": {
    "Enabled": true,
    "InitialUsername": "tgpanel",
    "InitialPassword": "tgpanel123",
    "CredentialsPath": "admin_auth.json"
  },
  "Hangfire": {
    "DashboardPath": "/hangfire"
  },
  "Serilog": {
    "Enabled": false,
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "System": "Warning"
      }
    },
    "RetainedFileCountLimit": 30
  },
  "AllowedHosts": "*"
}
