@namespace FragmentUsernameChecker.Pages
@using System.Text.Json
@using MudBlazor
@using TelegramPanel.Core.BatchTasks
@using TelegramPanel.Data.Entities
@using FragmentUsernameChecker.Services
@using FragmentUsernameChecker
@inject TelegramPanel.Core.Services.ChannelManagementService ChannelManagement
@inject TelegramPanel.Core.Services.ChannelGroupManagementService ChannelGroupManagement
@inject TelegramPanel.Core.Services.BatchTaskManagementService TaskManagement
@inject ISnackbar Snackbar
@inject NavigationManager Navigation

<MudText Typo="Typo.h4" Class="mb-4 tp-page-title">Fragment 用户名监控</MudText>

<MudPaper Class="pa-4" Elevation="0" Outlined="true">
    <MudStack Spacing="3">
        <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true">
            <b>定时抢注模式</b>：系统会持续监控用户名状态，一旦检测到 <b>Unavailable</b>，
            就会从所选分类的私密频道池里挑一个频道，直接切成公开并占用该用户名。
        </MudAlert>

        <!-- 用户名输入 -->
        <MudTextField @bind-Value="usernamesText"
                      Label="监控用户名列表（一行一个）" 
                      Variant="Variant.Outlined" 
                      Lines="8"
                      Placeholder="example1&#10;example2&#10;example3"
                      Disabled="@loading"
                      HelperText="每行一个用户名（不含 at 符号），只接受 Telegram 合法公开用户名格式" />

        <MudText Typo="Typo.caption" Class="mud-text-secondary">已输入 @GetUsernameCount() 个用户名</MudText>

        <MudDivider />

        <!-- 频道分类选择 -->
        <MudText Typo="Typo.subtitle1" Class="mt-2">选择目标频道分类</MudText>
        
        <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Dense="true" Class="mb-2">
            用户名可注册时，系统只会使用选中分类下的<b>私密频道</b>。频道必须是你创建的，且当前没有公开用户名。
        </MudAlert>

        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
            <MudText Typo="Typo.subtitle2">选择分类：@selectedGroups.Count / @channelGroups.Count</MudText>
            <MudSpacer />
            <MudButton Variant="Variant.Outlined" Color="Color.Primary" OnClick="SelectAllGroups"
                       Disabled="@(loading || channelGroups.Count == 0)">
                全选
            </MudButton>
            <MudButton Variant="Variant.Text" Color="Color.Secondary" OnClick="ClearGroups"
                       Disabled="@(loading || selectedGroups.Count == 0)">
                清空
            </MudButton>
        </MudStack>

        @if (loadingGroups)
        {
            <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
        }
        else if (channelGroups.Count == 0)
        {
            <MudText>暂无频道分类，请先创建频道分类或同步频道数据</MudText>
        }
        else
        {
            <MudTable Items="@channelGroups" Dense="true" Hover="true" Breakpoint="Breakpoint.Sm"
                      MultiSelection="true" @bind-SelectedItems="selectedGroups">
                <HeaderContent>
                    <MudTh>分类名称</MudTh>
                    <MudTh>可用私密频道数</MudTh>
                    <MudTh>说明</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="分类名称">@context.Name</MudTd>
                    <MudTd DataLabel="可用私密频道数">@GetChannelCount(context.Id)</MudTd>
                    <MudTd DataLabel="说明">@(!string.IsNullOrWhiteSpace(context.Description) ? context.Description : "-")</MudTd>
                </RowTemplate>
                <NoRecordsContent>
                    <MudText>暂无频道分类，请先创建频道分类或同步频道数据</MudText>
                </NoRecordsContent>
            </MudTable>
        }

        <MudDivider />

        <!-- 监控设置 -->
        <MudText Typo="Typo.subtitle1">监控设置</MudText>
        
        <MudGrid>
            <MudItem xs="12" sm="6">
                <MudNumericField @bind-Value="checkIntervalSeconds"
                                 Label="检查间隔（秒）" Variant="Variant.Outlined"
                                 Min="60" Max="3600" Step="30" Disabled="@loading"
                                 HelperText="每轮监控结束后的等待时间，建议 300 秒" />
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudNumericField @bind-Value="queryDelayMs"
                                 Label="查询延迟（毫秒）" Variant="Variant.Outlined"
                                 Min="500" Max="5000" Step="100" Disabled="@loading"
                                 HelperText="同一轮内逐个检查用户名时的间隔，避免请求过快" />
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudNumericField @bind-Value="durationHours"
                                 Label="运行时长（小时）" Variant="Variant.Outlined"
                                 Min="0" Max="720" Step="1" Disabled="@loading"
                                 HelperText="0 表示持续运行；程序重启后会自动尝试恢复该监控任务" />
            </MudItem>
        </MudGrid>

        <!-- 操作按钮 -->
        <MudStack Row="true" Spacing="2" Class="mt-2">
            <MudButton Variant="Variant.Filled" Color="Color.Success" 
                       StartIcon="@Icons.Material.Filled.PlaylistAdd"
                       Disabled="@(!CanSubmit)" OnClick="SubmitTaskAsync">
                创建监控任务
            </MudButton>
            <MudButton Variant="Variant.Outlined" Color="Color.Default" 
                       StartIcon="@Icons.Material.Filled.List"
                       OnClick="@(() => Navigation.NavigateTo("/tasks"))">
                查看任务中心
            </MudButton>
        </MudStack>
    </MudStack>
</MudPaper>

@code
{
    [Parameter] public string ModuleId { get; set; } = "";
    [Parameter] public string PageKey { get; set; } = "";

    private string usernamesText = "";
    private int checkIntervalSeconds = 300;
    private int queryDelayMs = 1500;
    private int durationHours = 0;
    private bool loading = false;
    private bool loadingGroups = true;

    private HashSet<ChannelGroup> selectedGroups = new();
    private List<ChannelGroup> channelGroups = new();
    private Dictionary<int, int> channelCountByGroup = new();

    private bool CanSubmit => !loading && GetUsernameCount() > 0 && selectedGroups.Count > 0;

    protected override async Task OnInitializedAsync()
    {
        await LoadChannelGroupsAsync();
    }

    private async Task LoadChannelGroupsAsync()
    {
        loadingGroups = true;
        try
        {
            var groups = await ChannelGroupManagement.GetAllGroupsAsync();
            channelGroups = groups.ToList();

            channelCountByGroup.Clear();
            foreach (var group in channelGroups)
            {
                var channels = await ChannelManagement.GetChannelsByGroupAsync(group.Id);
                channelCountByGroup[group.Id] = channels.Count(x =>
                    x.CreatorAccountId.HasValue &&
                    x.CreatorAccountId.Value > 0 &&
                    string.IsNullOrWhiteSpace(x.Username));
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"加载频道分类失败: {ex.Message}", Severity.Error);
        }
        finally
        {
            loadingGroups = false;
        }
    }

    private int GetUsernameCount()
    {
        if (string.IsNullOrWhiteSpace(usernamesText)) return 0;
        return usernamesText.Split('\n', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .Where(u => !string.IsNullOrWhiteSpace(u))
            .Select(u => u.Trim().TrimStart('@'))
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .Count();
    }

    private List<string> GetParsedUsernames()
    {
        if (string.IsNullOrWhiteSpace(usernamesText)) return new();
        return usernamesText.Split('\n', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .Where(u => !string.IsNullOrWhiteSpace(u))
            .Select(u => u.Trim().TrimStart('@'))
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .ToList();
    }

    private int GetChannelCount(int groupId)
    {
        return channelCountByGroup.TryGetValue(groupId, out var count) ? count : 0;
    }

    private void SelectAllGroups()
    {
        selectedGroups = new HashSet<ChannelGroup>(channelGroups);
        StateHasChanged();
    }

    private void ClearGroups()
    {
        selectedGroups.Clear();
        StateHasChanged();
    }

    private async Task SubmitTaskAsync()
    {
        var usernames = GetParsedUsernames();
        if (usernames.Count == 0)
        {
            Snackbar.Add("请输入至少一个用户名", Severity.Warning);
            return;
        }

        if (selectedGroups.Count == 0)
        {
            Snackbar.Add("请至少选择一个频道分类", Severity.Warning);
            return;
        }

        loading = true;
        try
        {
            var config = new FragmentUsernameTaskConfig
            {
                Usernames = usernames,
                TargetGroupIds = selectedGroups.Select(x => x.Id).ToList(),
                CheckIntervalSeconds = checkIntervalSeconds,
                QueryDelayMs = queryDelayMs,
                DurationHours = durationHours
            };

            var task = new BatchTask
            {
                TaskType = FragmentUsernameTaskHandler.TaskType,
                Total = usernames.Count,
                Completed = 0,
                Failed = 0,
                Config = JsonSerializer.Serialize(config, new JsonSerializerOptions { WriteIndented = true })
            };

            var created = await TaskManagement.CreateTaskAsync(task);
            
            Snackbar.Add($"监控任务已创建（ID: {created.Id}），将自动开始运行", Severity.Success);
            Navigation.NavigateTo("/tasks");
        }
        catch (Exception ex)
        {
            Snackbar.Add($"创建任务失败: {ex.Message}", Severity.Error);
        }
        finally
        {
            loading = false;
        }
    }
}
